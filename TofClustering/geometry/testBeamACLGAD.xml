<lccdd xmlns:compact="http://www.lcsim.org/schemas/compact/1.0"
       xmlns:xs="http://www.w3.org/2001/XMLSchema"
       xs:noNamespaceSchemaLocation="http://www.lcsim.org/schemas/compact/1.0/compact.xsd">

  <info name="testBeamACLGAD"
        title="testBeamACLGAD"
        author="Takuya Kumaoka"
        url="none"
        status="development"
        version="v0">
    <comment>8x2 strip beam test detector</comment>
  </info>

  <define>
    <constant name="tb_aclgad_pitch_x" value="0.5*mm"/>
    <constant name="tb_aclgad_pitch_y" value="20.0*mm"/>

    <constant name="tb_aclgad_size_x" value="4.0*mm"/>
    <constant name="tb_aclgad_size_y" value="20.0*mm"/>
    <constant name="tb_aclgad_size_z" value="0.3*mm"/>

    <constant name="tb_aclgad_pos_x" value="-2.0*mm"/>
    <constant name="tb_aclgad_pos_y" value="-20.0*mm"/>
    <constant name="tb_aclgad_pos_z" value="0.0*mm"/>
  </define>

  <readouts>
    <readout name="TOFBarrelHits">
      <segmentation type="CartesianGridXY"
                    grid_size_x="tb_aclgad_pitch_x"
                    grid_size_y="tb_aclgad_pitch_y"/>
      <id>system:8,layer:8,sensor:8,x:16,y:16</id>
    </readout>
  </readouts>

  <detectors>
    <detector id="0"
              name="testBeamACLGAD"
              type="testBeamACLGAD"
              readout="TOFBarrelHits">
      <position x="tb_aclgad_pos_x"
                y="tb_aclgad_pos_y"
                z="tb_aclgad_pos_z"/>
      <dimensions x="tb_aclgad_size_x"
                  y="tb_aclgad_size_y"
                  z="tb_aclgad_size_z"/>
      <material name="Silicon"/>
    </detector>
  </detectors>

</lccdd>