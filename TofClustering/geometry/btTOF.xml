<lccdd xmlns:compact="http://www.lcsim.org/schemas/compact/1.0"
       xmlns:xs="http://www.w3.org/2001/XMLSchema"
       xs:noNamespaceSchemaLocation="http://www.lcsim.org/schemas/compact/1.0/compact.xsd">

  <info name="BeamTestTOF"
        title="BeamTestTOF"
        author="Takuya Kumaoka"
        url="none"
        status="development"
        version="v0">
    <comment>Minimal beam test geometry</comment>
  </info>



  <debug>
    <type name="surface"       value="0"/>
    <type name="material"      value="0"/>
    <type name="readout"       value="0"/>
    <type name="segmentation"  value="0"/>
    <type name="limits"        value="0"/>
    <type name="region"        value="0"/>
    <type name="includes"      value="0"/>
  </debug>

  <std_conditions type="NTP"/>

  <define>
    <constant name="world_dx" value="1000*mm"/>
    <constant name="world_dy" value="1000*mm"/>
    <constant name="world_dz" value="1000*mm"/>
  </define>

  <includes>
    <gdmlFile ref="${DD4hepINSTALL}/DDDetectors/compact/elements.xml"/>
  </includes>


  <includes>
    <gdmlFile ref="${DD4hepINSTALL}/DDDetectors/compact/elements.xml"/>
    <gdmlFile ref="${DETECTOR_PATH}/compact/materials.xml"/>
  </includes>


  <world material="Air">
    <shape type="Box" dx="world_dx" dy="world_dy" dz="world_dz"/>
  </world>


  <limits>
    <limitset name="world_limits">
    </limitset>
    <limitset name="beamline_limits">
      <limit name="step_length_max" particles="*" value="1.0" unit="mm" />
      <limit name="track_length_max" particles="*" value="1.0" unit="mm" />
      <limit name="time_max" particles="*" value="0.1" unit="ns" />
      <limit name="ekin_min" particles="*" value="0.001" unit="MeV" />
      <limit name="range_min" particles="*" value="0.1" unit="mm" />
    </limitset>
    <limitset name="kill_limits">
      <limit name="time_max" particles="*" value="0.0" unit="ns"/>
    </limitset>
    <limitset name="cal_limits">
      <limit name="step_length_max" particles="*" value="5.0" unit="mm"/>
    </limitset>
  </limits>

  <include ref="testBeamACLGAD.xml"/>
  <!-- <include ref="/home/tkumaoka/eic/BeamTest/BeamTestEpicTof/TofClustering/testBeamACLGAD.xml"/> -->

</lccdd>




